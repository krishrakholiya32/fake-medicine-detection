# Python
__pycache__/
*.pyc
.venv/
venv/

# Models / weights (track only the exported ONNX + labels, not PT checkpoints)
*.pt
models/*.pt
# Allow the deployed model and labels
!models/*.onnx
!models/labels.json

# Training artifacts (large, regenerable)
training/data/
training/runs/

# Env
.env

# Node
frontend/node_modules/
frontend/dist/

# Uploads / storage
backend/storage/
backend/uploads/

# Zip archives from Kaggle downloads
*.zip

# OS
.DS_Store
Thumbs.db
